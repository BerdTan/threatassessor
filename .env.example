# ==============================================================================
# ThreatAssessor - Environment Configuration
# ==============================================================================
#
# This file contains environment variables for ThreatAssessor.
# Copy this file to .env and fill in your actual values.
#
# Quick Start (Minimal Configuration):
#   1. Copy: cp .env.example .env
#   2. Add OpenRouter API key: OPENROUTER_API_KEY=sk-or-v1-xxx
#   3. (Optional) Add Bedrock key for fallback: AWS_BEDROCK_API_KEY=ABSK...
#
# See docs/specs/MVP_SPECIFICATION.md for detailed LLM configuration guide.
#

# ==============================================================================
# LLM Provider Configuration (Multi-Provider Support)
# ==============================================================================

# Primary LLM Provider (for threat analysis)
# Options: openrouter, bedrock, anthropic, azure, vertex
# Default: openrouter (uses free tier models)
LLM_PROVIDER=openrouter

# Fallback Providers (comma-separated, in priority order)
# If primary fails, try these in order. Leave empty to disable fallback.
# Recommended: bedrock (enterprise reliability)
LLM_FALLBACK_PROVIDERS=bedrock

# LLM as Judge/Verifier (for Phase 3C validation)
# Typically use a high-quality model like Bedrock
# Used for: LLM critic agents (Architect, Tester, Red Team)
LLM_VERIFIER_PROVIDER=bedrock

# ==============================================================================
# OpenRouter Configuration (Recommended Primary Provider)
# ==============================================================================
#
# Get your free API key at: https://openrouter.ai/keys
# Free tier includes: nvidia/nemotron, google/gemma, meta/llama models
# Cost: $0.00 (free tier, rate limited)
#

# OpenRouter API Key (Required for LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=sk-or-v1-xxx

# OpenRouter Active Models (comma-separated, in priority order)
# Default: nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
# - Best free model for threat analysis (reasoning-optimized)
# - 30B parameters, good accuracy, reasonable speed
# - Free tier, rate limited
#
# Alternative free models:
# - google/gemma-4-31b-it:free (good for general analysis)
# - meta-llama/llama-3.3-70b-instruct:free (largest free model)
OPENROUTER_ACTIVE_MODELS=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# Legacy: Single model configuration (deprecated, use OPENROUTER_ACTIVE_MODELS)
# OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# ==============================================================================
# AWS Bedrock Configuration (Recommended Fallback Provider)
# ==============================================================================
#
# Get API key from: AWS Console → Bedrock → API Keys
# Docs: https://docs.aws.amazon.com/bedrock/latest/userguide/api-keys-use.html
# Cost: Pay-per-use (~$0.05 per analysis)
# Reliability: 99.9% uptime (enterprise-grade)
#

# Bedrock API Key (Required for LLM_FALLBACK_PROVIDERS=bedrock)
# Format: ABSK... (bearer token authentication)
AWS_BEDROCK_API_KEY=ABSK...

# AWS Region (Required for Bedrock)
# Recommended: us-east-1 (lowest latency, most models)
AWS_REGION=us-east-1

# Bedrock Model ID
# Default: us.anthropic.claude-sonnet-4-20250514-v1:0
# - Claude Sonnet 4: Best balance of speed/quality/cost
# - Latest model: 2025-05-14 version
#
# Alternative models:
# - us.anthropic.claude-opus-4-20250514-v1:0 (highest quality, slower, $$)
# - us.anthropic.claude-haiku-4-20250514-v1:0 (fastest, cheaper, $)
BEDROCK_MODEL=us.anthropic.claude-sonnet-4-20250514-v1:0

# ==============================================================================
# Embedding Configuration (Fixed Model)
# ==============================================================================
#
# Embedding model is FIXED and uses OpenRouter free tier.
# Model: nvidia/llama-nemotron-embed-vl-1b-v2:free
# - 2048 dimensions
# - Pre-computed cache: 45MB (834 MITRE techniques)
# - Cannot be changed (would break cache compatibility)
#
# No configuration needed - automatically uses OPENROUTER_API_KEY above.
#

# ==============================================================================
# Optional Provider Configurations
# ==============================================================================

# -----------------------------------------------------------------------------
# Anthropic Direct API (Alternative to Bedrock)
# -----------------------------------------------------------------------------
# Get API key at: https://console.anthropic.com/
# Use if: You want direct Anthropic API access without AWS
# Cost: Same as Bedrock, but different billing
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Azure OpenAI (Alternative Primary Provider)
# -----------------------------------------------------------------------------
# Get credentials from: Azure Portal → OpenAI Service
# Use if: You have Azure infrastructure, want GPT-4/4o
# Cost: Pay-per-use (similar to OpenRouter paid tiers)
# AZURE_OPENAI_KEY=your_azure_key_here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# -----------------------------------------------------------------------------
# Google Vertex AI (Alternative Primary Provider)
# -----------------------------------------------------------------------------
# Get credentials from: Google Cloud Console → Vertex AI
# Use if: You have GCP infrastructure, want Gemini models
# Cost: Pay-per-use (competitive with other providers)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_REGION=us-central1

# ==============================================================================
# Legacy/Optional Configuration
# ==============================================================================

# -----------------------------------------------------------------------------
# OpenAI API (Legacy - for agentic/ examples only)
# -----------------------------------------------------------------------------
# Not used by ThreatAssessor core, only for ADK examples in agentic/ folder
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Neo4j Database (Optional - for advanced graph features)
# -----------------------------------------------------------------------------
# Not required for core functionality
# Used for: Advanced agent workflows in agentic/ folder
# NEO4J_IMPORT_DIR=/path/to/neo4j/import
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your_neo4j_password

# ==============================================================================
# Configuration Verification
# ==============================================================================
#
# Minimal configuration (free tier):
#   1. OPENROUTER_API_KEY (required)
#   2. LLM_PROVIDER=openrouter (default)
#
# Recommended configuration (with fallback):
#   1. OPENROUTER_API_KEY (primary)
#   2. AWS_BEDROCK_API_KEY (fallback)
#   3. LLM_FALLBACK_PROVIDERS=bedrock
#
# Production configuration:
#   1. AWS_BEDROCK_API_KEY (primary)
#   2. LLM_PROVIDER=bedrock
#   3. LLM_FALLBACK_PROVIDERS=openrouter (reverse fallback)
#
# Test your configuration:
#   python3 -c "from agentic.llm_client import LLMClient; print(LLMClient.verify())"
#
