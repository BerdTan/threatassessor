# Exclude MITRE ATT&CK data files and generated pickle caches
chatbot/data/*.json
chatbot/data/*.pkl
chatbot/data/*.jsonl
chatbot/data/atlas/*.pkl
# CAVEAT techniques data (generated by scripts/data/fetch_caveat.py)
chatbot/data/caveat/caveat_techniques.yaml
chatbot/data/caveat/caveat_techniques.yaml.bak
# CCM mapping data (generated by scripts/data/fetch_ccm.py)
chatbot/data/ccm/ccm_by_technique.yaml
chatbot/data/ccm/ccm_by_technique.yaml.bak
chatbot/data/ccm/ccm_by_control.yaml
chatbot/data/ccm/ccm_by_control.yaml.bak
# SSP catalog data (generated by scripts/ingest/scrape_ssp_catalog.py)
chatbot/data/ssp/cybersecurity_catalog.json
chatbot/data/ssp/dss_catalog.json
chatbot/data/ssp/ssp_profiles.json
test/data/*.jsonl
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
ENV/
.env
.env.*
!.env.example
QUICK_START.md
.vscode/
*.code-workspace

# Claude Code settings (local permissions)
.claude/settings.local.json
.DS_Store
Thumbs.db
*.log
*.pid
*.backup
logs/

# Exclude codex (experimental features)
_codex/

# Exclude archive directories
.archive/
archive/

# Exclude generated report directories
report/

# Keep only JSON in ground_truth (no .md reports)
tests/data/ground_truth/*.md

# Test results (can be regenerated)
test_results_*.json

# Sample reports (keep in repo for reference)
!report_samples/
scripts/personal/
baseline_refactoring/

# Blog drafts (publish externally, not in repo)
docs/blog/

# Private decision log (personal reference, not for public repo)
docs/DECISIONS.md
chatbot/config/user_config.json
.claude/codemap/
