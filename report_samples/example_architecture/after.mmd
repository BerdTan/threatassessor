    %% ORIGINAL ARCHITECTURE
    Internet((Internet))
    WebServer[Web Server]
    Database[(Database)]

    %% RECOMMENDED SECURITY CONTROLS (GREEN)
    %% Format: Control Name<br/>MITRE: M####<br/>Addresses: T####
    NEW_LEASTPRIVILEGE["Least Privilege<br/>MITRE: M1016, M1018, M1026<br/>Contains: T1059, T1133, T1190<br/>Paths: #1, #2"]
    NEW_RATELIMITING["Rate Limiting<br/>MITRE: M1033, M1035, M1037<br/>Prevents: T1059, T1133, T1190<br/>Paths: #1"]
    NEW_LOGGING[/"Logging<br/>MITRE: M1047<br/>Detects: T1059, T1213<br/>Paths: #1, #2"/]
    NEW_PATCHING["Patching<br/>MITRE: M1017, M1051, M1054<br/>Prevents: T1190, T1203, T1213<br/>Paths: #1, #2"]
    NEW_USERTRAINING["User Training"]
    NEW_BACKUP[("Backup<br/>MITRE: M1053<br/>Recovers: T1485, T1486, T1490<br/>Paths: #1, #2")]
    NEW_EDR["Edr<br/>MITRE: M1040, M1049<br/>Prevents: T1059, T1486<br/>Paths: #1, #2"]
    NEW_WAF["Waf<br/>MITRE: M1037, M1050<br/>Prevents: T1190, T1203<br/>Paths: #1"]
    NEW_INPUTVALIDATION["Input Validation<br/>MITRE: M1050<br/>Prevents: T1190, T1203<br/>Paths: #1"]
    NEW_MFA["Mfa<br/>MITRE: M1032<br/>Prevents: T1133, T1213, T1485<br/>Paths: #1, #2"]
    NEW_CODESIGNING["Code Signing<br/>MITRE: M1038, M1045<br/>Prevents: T1059, T1490<br/>Paths: #1, #2"]
    NEW_VULNERABILITYSCANNING["Vulnerability Scanning<br/>MITRE: M1017<br/>Detects: T1213<br/>Paths: #1, #2"]
    NEW_NETWORKSEGMENTATION["Network Segmentation<br/>MITRE: M1030<br/>Contains: T1133, T1190<br/>Paths: #1"]
    NEW_AUDITLOG[/"Audit Log<br/>MITRE: M1047<br/>Detects: T1059, T1213<br/>Paths: #1, #2"/]
    NEW_BEHAVIORALANALYSIS["Behavioral Analysis<br/>MITRE: M1040<br/>Detects: T1059, T1486<br/>Paths: #1, #2"]
    NEW_DLP["Dlp<br/>MITRE: M1057<br/>Contains: T1005, T1567"]
    NEW_WEBCONTENTFILTERING["Web Content Filtering<br/>MITRE: M1021<br/>Prevents: T1567"]

    %% CONNECTIONS (with integrated controls)
    Internet --> NEW_MFA
    NEW_MFA --> WebServer
    WebServer --> NEW_MFA
    NEW_MFA --> Database
    Internet --> NEW_WAF
    NEW_WAF --> WebServer
    Database -.->|protected by| NEW_BACKUP
    WebServer -.->|logs to| NEW_LOGGING
    Database -.->|audits to| NEW_LOGGING
    Internet --> NEW_RATELIMITING
    NEW_RATELIMITING --> WebServer
    Internet --> NEW_INPUTVALIDATION
    NEW_INPUTVALIDATION --> WebServer
    WebServer -.->|protected by| NEW_EDR
    Database -.->|protected by| NEW_EDR
    Database -.->|monitored by| NEW_DLP
    WebServer -.->|filtered by| NEW_WEBCONTENTFILTERING
    NEW_NETWORKSEGMENTATION -.->|isolates| Database
    NEW_NETWORKSEGMENTATION -.->|isolates| WebServer
    NEW_LEASTPRIVILEGE -.->|applies to all| WebServer
    NEW_PATCHING -.->|applies to all| WebServer
    NEW_VULNERABILITYSCANNING -.->|applies to all| WebServer
    NEW_USERTRAINING -.->|applies to all| WebServer
    NEW_CODESIGNING -.->|applies to all| WebServer

    %% ORIGINAL ARCHITECTURE EDGES (below)
    Internet --> WebServer
    WebServer --> Database

